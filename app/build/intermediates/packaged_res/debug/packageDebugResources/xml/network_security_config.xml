<?xml version="1.0" encoding="utf-8"?>
<!--
  Permite tráfego HTTP cleartext para servidores IPTV que não usam HTTPS.
  Em produção, prefira sempre HTTPS quando disponível.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
